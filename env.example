# Database
DATABASE_URL=postgresql+asyncpg://agent_factory:agent_factory@localhost:5432/agent_factory

# Models (model-agnostic: provider/model-name)
ORCHESTRATOR_MODEL=google_genai/gemini-2.5-flash
IDEA_MODEL=google_genai/gemini-2.5-flash
WRITER_MODEL=google_genai/gemini-2.5-flash
IMAGE_MODEL=gemini-3-pro-image-preview
EDIT_MODEL=gemini-3-pro-image-preview
VIDEO_MODEL=veo-3.1-generate-preview
CAPTION_MODEL=gemini-2.5-flash

# API Keys (at least one required)
GOOGLE_API_KEY=your-google-api-key-here

# LangSmith (optional - for tracing)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agent-factory-v4
LANGCHAIN_TRACING_V2=false

# Server
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
